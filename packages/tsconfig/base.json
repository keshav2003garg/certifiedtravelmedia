{
  "$schema": "https://json.schemastore.org/tsconfig",

  "display": "Default",

  "compilerOptions": {
    "target": "ES2022",

    "strict": true,
    "skipLibCheck": true,

    "allowJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,

    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,

    "noEmit": true
  },

  "exclude": ["node_modules"]
}
