{
  "name": "@services/database",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "db:generate": "dotenv -e ../../.env.development.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env.development.local -- drizzle-kit migrate"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@repo/esconfig": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    }
  }
}
